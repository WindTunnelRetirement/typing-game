<!-- app/views/typing_problems/play.html.erb -->
<div class="max-w-xl mx-auto mt-10 p-6 bg-white rounded-xl shadow">
  <h1 class="text-2xl font-bold mb-4">タイピング問題に挑戦</h1>

  <div class="mb-4">
    <p class="text-gray-700">問題文：</p>
    <div id="problem-display" class="font-mono text-lg bg-gray-100 p-3 rounded mb-4 whitespace-pre-wrap"></div>
  </div>

  <div class="mb-4">
    <label for="typing-input" class="block text-gray-700">入力欄:</label>
    <input
      type="text"
      id="typing-input"
      class="w-full p-2 border rounded focus:outline-none focus:ring"
      placeholder="ここにタイピングしてね"
    />
  </div>

  <div id="result" class="mt-4 text-lg font-bold"></div>
</div>

<script>
  document.addEventListener("turbo:load", () => {
    const input = document.getElementById("typing-input");
    const display = document.getElementById("problem-display");
    const resultDiv = document.getElementById("result");

    const answer = "<%= j @typing_problem.content %>";
    const nextUrl = "<%= @next_problem ? play_typing_problem_path(@next_problem) : root_path %>";

    function renderProblem() {
      display.innerHTML = "";
      for (let i = 0; i < answer.length; i++) {
        const span = document.createElement("span");
        span.textContent = answer[i];
        span.dataset.index = i;
        display.appendChild(span);
      }
    }

    let startTime = null;

    input.addEventListener("input", () => {
      const userInput = input.value;
      const spans = display.querySelectorAll("span");

      if (startTime === null && userInput.length > 0) {
        startTime = new Date();
      }

      let allCorrect = true;

      for (let i = 0; i < spans.length; i++) {
        const expectedChar = answer[i];
        const typedChar = userInput[i];

        if (typedChar == null) {
          spans[i].className = "";
          allCorrect = false;
        } else if (typedChar === expectedChar) {
          spans[i].className = "text-green-600";
        } else {
          spans[i].className = "text-red-600";
          allCorrect = false;
        }
      }

      if (userInput.length === answer.length) {
        const endTime = new Date();
        const elapsed = ((endTime - startTime) / 1000).toFixed(2);

        let correctCount = 0;
        for (let i = 0; i < answer.length; i++) {
          if (userInput[i] === answer[i]) {
            correctCount++;
          }
        }

        const accuracy = ((correctCount / answer.length) * 100).toFixed(1);
        const wpm = (answer.length / elapsed).toFixed(2);

        if (correctCount === answer.length) {
          resultDiv.innerHTML = `✅ <span class="text-green-600">${elapsed} 秒</span>で正解！<br>
            📈 速度: <span class="font-bold">${wpm}文字/秒</span><br>
            🎯 正確率: <span class="font-bold">${accuracy}%</span><br>
            ⌨️ Enterキーで次へ`;
          resultDiv.className = "mt-4 text-green-600 text-lg font-bold";
        } else {
          resultDiv.innerHTML = `❌ 間違いがあります<br>
            📈 速度: <span class="font-bold">${wpm}文字/秒</span><br>
            🎯 正確率: <span class="font-bold text-yellow-600">${accuracy}%</span><br>
            ⌨️ Enterキーでリトライ`;
          resultDiv.className = "mt-4 text-red-600 text-lg font-bold";
        }
      }
    });

    // Enterキーで遷移 or リセット
    input.addEventListener("keydown", (e) => {
      if (e.key === "Enter" && input.value.length === answer.length) {
        const spans = display.querySelectorAll("span");
        const correct = [...spans].every(span => span.className === "text-green-600");

        if (correct) {
          window.location.href = nextUrl;
        } else {
          input.value = "";
          resultDiv.textContent = "";
          spans.forEach(span => span.className = "");
        }
      }
    });

    renderProblem();
  });
</script>