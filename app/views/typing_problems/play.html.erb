<!-- app/views/typing_problems/play.html.erb -->
<div class="max-w-xl mx-auto mt-10 p-6 bg-white rounded-xl shadow">
  <h1 class="text-2xl font-bold mb-4">タイピング問題に挑戦</h1>

  <div class="mb-4">
    <p class="text-gray-700">問題文：</p>
    <div id="problem-display" class="font-mono text-lg bg-gray-100 p-3 rounded mb-4 whitespace-pre-wrap"></div>
  </div>

  <div class="mb-4">
    <label for="typing-input" class="block text-gray-700">入力欄:</label>
    <input
      type="text"
      id="typing-input"
      class="w-full p-2 border rounded focus:outline-none focus:ring"
      placeholder="ここにタイピングしてね"
    />
  </div>

  <div id="result" class="mt-4 text-lg font-bold"></div>
</div>

<script>
  document.addEventListener("turbo:load", () => {
    const input = document.getElementById("typing-input");
    const display = document.getElementById("problem-display");
    const result = document.getElementById("result");
    const answer = "<%= j @typing_problem.content %>";
    const nextUrl = "<%= @next_problem.present? ? play_typing_problem_path(@next_problem) : root_path %>";

    let completed = false;
    const startTime = performance.now();

    function renderProblem() {
      display.innerHTML = "";
      for (let i = 0; i < answer.length; i++) {
        const span = document.createElement("span");
        span.textContent = answer[i];
        span.dataset.index = i;
        display.appendChild(span);
      }
    }

    input.addEventListener("input", () => {
      const userInput = input.value;
      const spans = display.querySelectorAll("span");
      let correctCount = 0;

      for (let i = 0; i < spans.length; i++) {
        const expectedChar = answer[i];
        const typedChar = userInput[i];

        if (typedChar == null) {
          spans[i].className = "";
        } else if (typedChar === expectedChar) {
          spans[i].className = "text-green-600";
          correctCount++;
        } else {
          spans[i].className = "text-red-600";
        }
      }

      if (userInput === answer && !completed) {
        completed = true;
        const endTime = performance.now();
        const seconds = ((endTime - startTime) / 1000).toFixed(2);
        const speed = (answer.length / seconds).toFixed(2);
        const accuracy = ((correctCount / answer.length) * 100).toFixed(1);
        result.innerHTML = `✅ ${seconds} 秒で正解！<br>📈 速度: ${speed}文字/秒<br>🎯 正確率: ${accuracy}%<br>⌨️ Enterキーで次へ`;

        // Enterで次へ
        document.addEventListener("keydown", (e) => {
          if (e.key === "Enter") {
            window.location.href = nextUrl;
          }
        });
      }
    });

    renderProblem();
  });
</script>
